{
  "compilerOptions": {
    "target": "es2020",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "strict": true,
    "types": ["bun", "preact"],
    "paths": {
      "@expressive/mvc/*": ["../mvc/src/*"],
      "@expressive/*": ["../*/src"],
      "@expressive/react/state": ["../react/src/state"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
