{
  "name": "@expressive/preact",
  "version": "0.77.0",
  "private": true,
  "description": "Use classes to define state in Preact!",
  "license": "MIT",
  "author": {
    "name": "Gabe Klein",
    "email": "gabe@expressive.dev",
    "url": "https://github.com/gabeklein"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabeklein/expressive-state.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && bun build --outdir=dist --root=src --format=esm --target=browser --sourcemap=external --packages=external src/index.ts",
    "test": "tsc --noEmit && bun test --coverage",
    "preversion": "npm run test && npm run build"
  },
  "dependencies": {
    "@expressive/react": "^0.77.0",
    "@expressive/state": "^0.73.1"
  },
  "devDependencies": {
    "@testing-library/preact": "^3.2.3",
    "preact": "^10.0.0"
  },
  "peerDependencies": {
    "preact": "^10.0.0"
  }
}