{
  "compilerOptions": {
    "target": "es2020",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@expressive/mvc",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "strict": true,
    "types": ["bun", "react"],
    "paths": {
      "@expressive/mvc/*": ["../mvc/src/*"],
      "@expressive/*": ["../*/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
