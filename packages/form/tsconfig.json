{
  "compilerOptions": {
    "target": "es2020",
    "esModuleInterop": true,
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "strict": true,
    "types": ["bun"],
    "paths": {
      "@expressive/mvc/*": ["../mvc/src/*"],
      "@expressive/*": ["../*/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
