{
  "name": "@expressive/react",
  "version": "0.77.0",
  "description": "Use classes to define state in React!",
  "keywords": [
    "expressive",
    "react",
    "state"
  ],
  "license": "MIT",
  "author": {
    "name": "Gabe Klein",
    "email": "gabe@termtm.com",
    "url": "https://github.com/gabeklein"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabeklein/expressive-mvc.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./src/jsx-runtime.ts"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "default": "./dist/state.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "tsc --noEmit && bun test --coverage --only-failures"
  },
  "dependencies": {
    "@expressive/mvc": "^0.77.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsdown": "^0.20.1"
  },
  "peerDependencies": {
    "react": ">=16.8.0 <20.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
