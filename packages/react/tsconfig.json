{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "target": "es2020",
    "esModuleInterop": true,
    "lib": ["ES2018", "DOM"],
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "sourceMap": true,
    "strict": true,
    "types": [ "jest", "react" ]
  },
  "exclude": [
    "node_modules",
    "./dist"
  ]
}