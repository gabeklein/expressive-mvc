{
  "compilerOptions": {
    "target": "es2020",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@expressive/cli",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "noUnusedLocals": true,
    "sourceMap": true,
    "strict": true,
    "types": ["bun", "node"],
    "paths": {
      "@expressive/mvc/*": ["../mvc/src/*"],
      "@expressive/mvc": ["../mvc/src"],
      "@expressive/cli": ["./src/index"],
      "@expressive/cli/jsx-runtime": ["./src/jsx-runtime"],
      "@expressive/cli/jsx-dev-runtime": ["./src/jsx-dev-runtime"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
