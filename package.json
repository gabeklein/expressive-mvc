{
  "name": "expressive-mvc",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "website",
    "examples"
  ],
  "scripts": {
    "test": "lerna run test",
    "build": "lerna run build",
    "pr": "bash .github/scripts/pr.sh",
