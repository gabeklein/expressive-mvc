    "nuke": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.2.0",
    "@types/react": "^19",
    "lerna": "^9.0.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  }
}
