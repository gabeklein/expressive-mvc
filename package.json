  "devDependencies": {
    "@types/node": "^25.2.0",
    "@types/react": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^27.4.0",
    "lerna": "^9.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  }
}
