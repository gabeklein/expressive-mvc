{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Develop examples with debugger",
      "type": "chrome",
      "request": "launch",
      "port": 9222,
      "url": "http://localhost:5173/",
      "webRoot": "${workspaceFolder}/",
      "sourceMaps": true
    },
    {
      "type": "bun",
      "request": "launch",
      "name": "Bun Tests (current file)",
      "runtime": "bun",
      "program": "${relativeFile}",
      "runtimeArgs": ["test"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "cwd": "${workspaceFolder}"
    }
  ]
}
