{
    "name": "expressive-mvc",
    "build": {
        "dockerfile": "Dockerfile.dev",
        "context": ".."
    },
    "remoteUser": "bun",
    "userEnvProbe": "loginInteractiveShell",
    "postCreateCommand": "sudo mkdir -p /workspaces/.claude && sudo chown -R bun:bun /workspaces/.claude /home/bun/.bun/install/cache && bash .devcontainer/restore-claude-auth.sh && bun install",
    "postStartCommand": "bash .devcontainer/start-remote-control.sh",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "containerEnv": {
        "CLAUDE_CONFIG_DIR": "/workspaces/.claude"
    },
    "mounts": [
        "source=expressive-mvc-bun-cache,target=/home/bun/.bun/install/cache,type=volume"
    ],
    "forwardPorts": [5173],
    "portsAttributes": {
        "5173": { "label": "dev server (vite)" }
    },
    "customizations": {
        "vscode": {
            "settings": {
                "editor.tabSize": 2,
                "editor.detectIndentation": true
            },
            "extensions": [
                "esbenp.prettier-vscode",
                "Oven.bun-vscode"
            ]
        }
    }
}
